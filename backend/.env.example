# ==============================
# Servidor
# ==============================
PORT=3001
NODE_ENV=development

# ==============================
# Banco de Dados (Supabase / PostgreSQL)
# ==============================
# Copie a "Connection string" do painel do Supabase em:
# Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# ==============================
# JWT
# ==============================
# Gere um segredo forte: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_DE_64_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==============================
# CORS
# ==============================
# URL do frontend em produção
FRONTEND_URL=https://seu-dominio.com.br

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
